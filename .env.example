# ═══════════════════════════════════════════
#   FIGURINHA COPA 2026 — VARIÁVEIS DE AMBIENTE
# ═══════════════════════════════════════════

# ── Ambiente ─────────────────────────────
NODE_ENV=production

# ── OpenAI ───────────────────────────────
# Em producao, deixe true para gerar a figurinha completa via OpenAI gpt-image-2.
# O modelo recebe a figurinha-modelo (raphinha.png) + a foto do user e devolve
# a figurinha final pronta em uma unica chamada (edit endpoint, 2 imagens).
OPENAI_GENERATION_ENABLED=true
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
# medium e o sweet spot para edits de identidade com gpt-image-2.
# low pode degradar a preservacao do rosto. high custa mais (~4x medium).
OPENAI_IMAGE_QUALITY=medium
# Retrato 2:3 e o formato natural da figurinha Panini. Outros validos:
# 1024x1024 (quadrado), 1024x1536 (retrato), 1536x1024 (paisagem).
OPENAI_IMAGE_SIZE=1024x1536
# Timeout da chamada images.edit em ms. gpt-image-2 medium leva 20-180s.
# 290000 = 290s, logo abaixo do maxDuration:300 do Vercel para evitar 504.
OPENAI_GENERATION_TIMEOUT_MS=290000

# ── Arte final ───────────────────────────
WATERMARK_TEXT=ESTA FIGURINHA TEM DIREITOS AUTORAIS - PREVIEW PROTEGIDO - NAO COPIAR
