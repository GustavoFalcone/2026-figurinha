OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=high

# ── Arte final ───────────────────────────
WATERMARK_TEXT=ESTA FIGURINHA TEM DIREITOS AUTORAIS - PREVIEW PROTEGIDO - NAO COPIAR
